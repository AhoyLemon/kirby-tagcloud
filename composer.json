{
  "name": "ahoylemon/kirby-tagcloud",
  "type": "kirby-plugin",
  "version": "1.0.1",
  "description": "Tag cloud and tag filtering for Kirby 5 — configurable field, template scope, min-count, sort order, and limit",
  "homepage": "https://github.com/ahoylemon/kirby-tagcloud",
  "license": "MIT",
  "authors": [
    {
      "name": "Lemon",
      "email": "lemon@thefpl.us"
    }
  ],
  "keywords": [
    "kirby",
    "kirby-cms",
    "kirby-plugin",
    "tags",
    "tagcloud",
    "tag-cloud",
    "tag-results",
    "kirby5"
  ],
  "require": {
    "php": ">=8.1",
    "getkirby/composer-installer": "^1.2"
  },
  "config": {
    "allow-plugins": {
      "getkirby/composer-installer": true
    }
  }
}
